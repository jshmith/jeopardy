# Firebase web app config — from Firebase Console > Project settings > General > Your apps > Web app.
# Create a free Firebase project (Spark plan, no credit card required) at https://console.firebase.google.com/
# then enable: Firestore Database (production mode) and Authentication > Sign-in method > Anonymous.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
